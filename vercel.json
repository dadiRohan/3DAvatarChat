{
  "version": 2,
  "routes": [
    {
      "src": "/public/models/(.*)",
      "headers": {
        "Content-Type": "model/gltf-binary",
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/public/models/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}